// Blink D1 — libreria MultiFuncShield
// D1=pin13 (LOW=acceso, HIGH=spento)

#include <MultiFuncShield.h>

void setup() {
  // D2, D3, D4 spenti
  pinMode(12, OUTPUT); digitalWrite(12, HIGH);
  pinMode(11, OUTPUT); digitalWrite(11, HIGH);
  pinMode(10, OUTPUT); digitalWrite(10, HIGH);
  pinMode(13, OUTPUT);
}

void loop() {
  digitalWrite(13, LOW);   // D1 acceso
  delay(1000);
  digitalWrite(13, HIGH);  // D1 spento
  delay(1000);
}
